# docker-stack-installer 全体の動きを決める設定です。
# ここでは「どこへ clone するか」「どのサービスを対象にするか」を決めます。

# sibling repo を clone する親ディレクトリです。
# 例: /home/yourname/docker-stack
STACK_ROOT=/path/to/workspace

# GitHub の owner / user 名です。
STACK_GITHUB_OWNER=Arrumis

# clone 方法です。普段は https のままで大丈夫です。
CLONE_PROTOCOL=https

# 既定で管理対象にするサービス一覧です。
# 基本はこのままで、要らないものは EXCLUDED_SERVICES 側で外します。
SERVICES="infra-reverse-proxy infra-fail2ban infra-munin app-tategaki app-wordpress app-ttrss app-syncthing app-openvpn app-mirakurun-epgstation"

# 上の一覧から除外するサービスです。
# 例: EXCLUDED_SERVICES="infra-munin app-openvpn"
EXCLUDED_SERVICES=""

# 1 にすると、起動後に reverse proxy を HTTP から HTTPS へ自動昇格します。
# 証明書取得に失敗した場合は HTTP のまま止まります。
AUTO_ENABLE_HTTPS=1
