# Base directory where sibling repositories are checked out
STACK_ROOT=/path/to/workspace
STACK_GITHUB_OWNER=Arrumis
CLONE_PROTOCOL=https

# Default services to check or start
SERVICES="infra-reverse-proxy infra-fail2ban infra-munin app-tategaki app-wordpress app-ttrss app-syncthing app-openvpn app-mirakurun-epgstation"

# Services to skip from the default list above
# Example: EXCLUDED_SERVICES="infra-munin app-openvpn"
EXCLUDED_SERVICES=""

# Try to switch the reverse proxy from HTTP to HTTPS automatically after install.
# When the certificate request fails, the stack stays in HTTP mode.
AUTO_ENABLE_HTTPS=1
